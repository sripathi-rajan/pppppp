# DriveLegal — Production Environment Variables
# Deploy this as backend/.env on the AWS EC2 instance (13.50.138.113)

# ── Ollama (Local AI — GPU-accelerated on g4dn.xlarge) ─────────────────────
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.1:8b

# ── Gemini API Key (Cloud AI — Fallback if Ollama fails) ───────────────────
# Get a free key at: https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=your_gemini_api_key_here

# ── Server Settings ───────────────────────────────────────────────────────────
PORT=8000
PRODUCTION=true
