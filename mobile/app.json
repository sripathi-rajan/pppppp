{
  "expo": {
    "name": "DriveLegal",
    "slug": "drivelegal-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",

    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FBF7F0"
    },
    "updates": {
      "url": "https://u.expo.dev/7cd91a27-1ba3-41a0-bf6a-d2a59eb7a131",
      "enabled": true,
      "fallbackToCacheTimeout": 0
    },
    "runtimeVersion": "1.0.0",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.dakshankarthic.drivelegal",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "DriveLegal needs microphone access for voice search."
      }
    },
    "extra": {
      "router": {
        "root": "./app"
      },
      "eas": {
        "projectId": "7cd91a27-1ba3-41a0-bf6a-d2a59eb7a131"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.dakshankarthic.drivelegal",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyDTfY-7KE8S7fhS2CaxXK0-QZFRWuWCZnc"
        }
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow DriveLegal to use your location for traffic rules and zone detection."
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "Allow DriveLegal to access your microphone for voice search."
        }
      ],
      "expo-web-browser",
      "expo-sqlite",
      "expo-status-bar",
      "expo-image-picker",
      "expo-splash-screen"
    ],
    "scheme": "drivelegal",
    "owner": "ishwarya19"
  }
}
